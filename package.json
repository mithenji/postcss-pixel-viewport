{
  "name": "postcss-pixel-viewport",
  "version": "0.1.2",
  "description": "A modern PostCSS 8+ plugin that converts pixel units into viewport-relative units.",
  "keywords": [
    "css",
    "postcss",
    "postcss-plugin",
    "pixel",
    "px",
    "viewport",
    "vw",
    "vh",
    "vmin",
    "vmax",
    "responsive",
    "mobile"
  ],
  "license": "MIT",
  "author": "postcss-pixel-viewport contributors",
  "contributors": [],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.18.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mithenji/postcss-pixel-viewport.git"
  },
  "homepage": "https://github.com/mithenji/postcss-pixel-viewport#readme",
  "bugs": {
    "url": "https://github.com/mithenji/postcss-pixel-viewport/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/fix-cjs.cjs",
    "clean": "rimraf dist coverage",
    "dev": "tsup --watch",
    "example:advanced": "npm run build && postcss examples/advanced/src/input.css -o examples/advanced/src/output.css --config examples/advanced",
    "example:basic": "npm run build && postcss examples/basic/src/input.css -o examples/basic/src/output.css --config examples/basic",
    "format": "prettier --write .",
    "lint": "eslint .",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm run lint && npm run build && npm test && npm run test:smoke && npm run pack:dry",
    "test": "vitest run",
    "test:smoke": "npm run build && node test/smoke/cjs.cjs && node test/smoke/esm.mjs && tsc -p test/smoke/tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "postcss-value-parser": "^4.2.0"
  },
  "peerDependencies": {
    "postcss": "^8.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
